<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="365.0" prefWidth="470.0" style="-fx-background-color: #E6E6FA;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.Controllers.deleteItems">
   <children>
      <Text layoutX="165.0" layoutY="55.0" strokeType="OUTSIDE" strokeWidth="0.0" text="Delete Item">
         <font>
            <Font size="25.0" />
         </font>
      </Text>
      <Label layoutX="93.0" layoutY="105.0" text="Enter Item Code you wish to delete:">
         <font>
            <Font size="18.0" />
         </font>
      </Label>
      <TextField fx:id="deleteItemField" layoutX="154.0" layoutY="170.0" />
      <Button fx:id="deleteButton" layoutX="116.0" layoutY="255.0" mnemonicParsing="false" onAction="#deleteByCode" text="Delete Item">
         <font>
            <Font size="14.0" />
         </font></Button>
      <Button fx:id="cancelButton" layoutX="277.0" layoutY="255.0" mnemonicParsing="false" onAction="#cancelAndClose" style=": #bd91db;" text="Cancel">
         <font>
            <Font size="14.0" />
         </font></Button>
   </children>
</AnchorPane>
